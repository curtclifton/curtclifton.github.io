		},
		
		{
			"id": "http://curt.micro.blog/2017/08/18/but-it-seems.html",
	      	
			"content_html": "<p>“But it seems like only when actual swastikas show up do [Republicans] say anything.” —<a href=\"http://inessential.com/2017/08/18/republicans_have_been_playing_with_racis\">Brent Simmons</a></p>\n",
			"date_published": "2017-08-18T14:12:00-07:00",
